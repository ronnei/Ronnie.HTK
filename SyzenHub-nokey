-- Hàm tạo thông báo đỏ nhẹ khi sao chép
local function NotifyMessage(text, color, duration)
    local NotifyGui = Instance.new("ScreenGui")
    NotifyGui.Parent = game.CoreGui
    
    local Label = Instance.new("TextLabel")
    Label.Parent = NotifyGui
    Label.Size = UDim2.new(0, 600, 0, 50)
    Label.Position = UDim2.new(0.5, -300, 0.15, 0)
    Label.BackgroundTransparency = 1
    Label.TextColor3 = color or Color3.fromRGB(255, 110, 110)
    Label.Text = text
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 25
    Label.TextStrokeTransparency = 0.5
    Label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    task.spawn(function()
        task.wait(duration or 3.5)
        for i = 0, 1, 0.1 do
            Label.TextTransparency = i
            Label.TextStrokeTransparency = 0.5 + (i * 0.5)
            task.wait(0.05)
        end
        NotifyGui:Destroy()
    end)
end

