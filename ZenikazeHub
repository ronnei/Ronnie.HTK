-- Hàm tạo THÔNG BÁO CHỮ ĐỎ NHẸ RÕ NÉT (Giữ nguyên)
local function NotifyRed(text)
    local NotifyGui = Instance.new("ScreenGui")
    NotifyGui.Parent = game.CoreGui
    
    local Label = Instance.new("TextLabel")
    Label.Parent = NotifyGui
    Label.Size = UDim2.new(0, 550, 0, 60) -- Tăng kích thước nhẹ
    Label.Position = UDim2.new(0.5, -275, 0.15, 0) -- Vị trí cao hơn
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.fromRGB(255, 120, 120) -- Màu đỏ nhẹ
    Label.Text = text
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 26 -- Phông chữ rõ nét hơn
    Label.TextStrokeTransparency = 0.3
    Label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    task.spawn(function()
        task.wait(3.5)
        for i = 0, 1, 0.1 do
            Label.TextTransparency = i
            Label.TextStrokeTransparency = 0.3 + (i * 0.7)
            task.wait(0.05)
        end
        NotifyGui:Destroy()
    end)
end

