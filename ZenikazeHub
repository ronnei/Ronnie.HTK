local ImageId = "https://violent-black-rwtqpfi4zc.edgeone.app/" -- Link ảnh Itachi của bạn

-- Lớp ảnh 1
local MovingImage1 = Instance.new("ImageLabel", ImageContainer)
MovingImage1.Size = UDim2.new(2, 0, 2, 0) -- Kích thước gấp đôi để trôi mượt
MovingImage1.Position = UDim2.new(0, 0, 0, 0)
MovingImage1.Image = ImageId
MovingImage1.ScaleType = Enum.ScaleType.Tile -- Chế độ lặp lại
MovingImage1.TileSize = UDim2.new(1, 0, 1, 0)
MovingImage1.BackgroundTransparency = 1
MovingImage1.ImageTransparency = 0.3 -- Làm mờ ảnh nhẹ

-- Lớp ảnh 2 (để lặp lại mượt mà)
local MovingImage2 = Instance.new("ImageLabel", ImageContainer)
MovingImage2.Size = MovingImage1.Size
MovingImage2.Position = UDim2.new(MovingImage1.Position.X.Scale + 2, 0, 0, 0)
MovingImage2.Image = MovingImage1.Image
MovingImage2.ScaleType = MovingImage1.ScaleType
MovingImage2.TileSize = MovingImage1.TileSize
MovingImage2.BackgroundTransparency = 1
MovingImage2.ImageTransparency = MovingImage1.ImageTransparency

-- Hàm xử lý chuyển động của hình nền
task.spawn(function()
    local scrollSpeed = 0.0001 -- Tốc độ trôi
    while MovingImage1.Parent do
        task.wait()
        MovingImage1.Position = UDim2.new(MovingImage1.Position.X.Scale - scrollSpeed, 0, 0, 0)
        MovingImage2.Position = UDim2.new(MovingImage2.Position.X.Scale - scrollSpeed, 0, 0, 0)

        if MovingImage1.Position.X.Scale <= -2 then
            MovingImage1.Position = UDim2.new(0, 0, 0, 0)
            MovingImage2.Position = UDim2.new(2, 0, 0, 0)
        end
    end
end)

